{
  "mcpServers": {
    "mcpserver_spectrum": {
      "name": "mcpserver_spectrum",
      "install": {
        "commands": [
          "python -m pip install --upgrade pip",
          "pip install -r requirements.txt"
        ]
      },
      "start": {
        "command": "python",
        "args": ["server.py"],
        "env": {
          "HTTP_BIND": "0.0.0.0",
          "HTTP_PORT": "8000"
        }
      }
    }
  }
}
