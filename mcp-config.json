{
  "mcpServers": {
    "mcpserver_spectrum": {
      "type": "streamable_http",
      "url": "http://localhost:8000",
      "name": "mcpserver_spectrum",
      "description": "Spectrum MCP server configuration",
      "install": {
        "commands": ["pip install flask pyserial"]
      },
      "start": {
        "command": "python",
        "args": ["server.py"]
      },
      "service": {
        "port": 8000,
        "protocol": "http"
      }
    }
  }
}
